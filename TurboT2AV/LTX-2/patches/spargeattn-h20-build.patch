+++ b/setup.py
@@ -18,0 +19 @@ from pathlib import Path
+import site
@@ -27,0 +29,2 @@ from torch.utils.cpp_extension import BuildExtension, CUDAExtension, CUDA_HOME
+HAS_SM80 = False
+HAS_SM89 = False
@@ -50,0 +54,21 @@ def get_instantiations(src_dir: str):
+def get_nvidia_include_dirs() -> List[str]:
+    include_dirs = []
+    if CUDA_HOME is not None:
+        for cuda_include in [
+            Path(CUDA_HOME) / "include",
+            Path(CUDA_HOME) / "targets" / "x86_64-linux" / "include",
+        ]:
+            if cuda_include.is_dir():
+                include_dirs.append(str(cuda_include))
+    for site_package in site.getsitepackages():
+        nvidia_dir = Path(site_package) / "nvidia"
+        if not nvidia_dir.is_dir():
+            continue
+        for include_dir in nvidia_dir.glob("*/include"):
+            if not include_dir.is_dir():
+                continue
+            if include_dir.parent.name.startswith("cu13"):
+                continue
+            include_dirs.append(str(include_dir))
+    return include_dirs
+
